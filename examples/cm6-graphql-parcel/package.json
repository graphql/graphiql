{
  "name": "example-cm6-graphql-parcel",
  "version": "0.0.0",
  "license": "MIT",
  "description": "GraphiQL Parcel Example",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "parcel src/index.html -p 8080",
    "build": "parcel build src/index.html --public-url /",
    "build-demo": "yarn build && mkdirp ../../packages/graphiql/cm6 && cp -r dist ../../packages/graphiql/cm6/"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6",
    "@codemirror/commands": "^6",
    "@codemirror/language": "^6",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6",
    "cm6-graphql": "^0.0",
    "graphql": "^16"
  },
  "devDependencies": {
    "parcel": "^2",
    "worker-loader": "^2",
    "typescript": "^4"
  }
}

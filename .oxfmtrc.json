{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "proseWrap": "never",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "packages/codemirror-graphql/src/__tests__/schema-kitchen-sink.graphql",
    "**/CHANGELOG.md"
  ],
  "overrides": [
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "proseWrap": "preserve"
      }
    }
  ]
}
